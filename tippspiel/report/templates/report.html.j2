{% macro fixture_data(d) %}
<div class="fixture-data">
  <table class="kv">
    <tr><th>Model L/D/W</th><td>{{ "%.1f"|format(d.ldw.home*100) }}% / {{ "%.1f"|format(d.ldw.draw*100) }}% / {{ "%.1f"|format(d.ldw.away*100) }}%</td></tr>
    <tr><th>Expected goals</th><td>{{ "%.2f"|format(d.exp_goals.home) }}–{{ "%.2f"|format(d.exp_goals.away) }} <span class="sub">(total {{ "%.2f"|format(d.exp_goals.total) }})</span></td></tr>
    {% if d.elo %}<tr><th>Elo</th><td>{{ "%.0f"|format(d.elo.home) }} vs {{ "%.0f"|format(d.elo.away) }} <span class="sub">(Δ {{ "%+.0f"|format(d.elo.diff) }})</span></td></tr>{% endif %}
    {% if d.offdef %}<tr><th>Attack / defence</th><td>{{ d.offdef.home_name }} att <b>{{ "%+.2f"|format(d.offdef.att_home) }}</b> / def <b>{{ "%+.2f"|format(d.offdef.def_home) }}</b> · {{ d.offdef.away_name }} att <b>{{ "%+.2f"|format(d.offdef.att_away) }}</b> / def <b>{{ "%+.2f"|format(d.offdef.def_away) }}</b> <span class="sub">(off/def goal-volume {{ d.offdef.pct }})</span></td></tr>{% endif %}
    <tr><th>Top scorelines</th><td>{% for h, a, p in d.top3 %}{{ h }}–{{ a }} ({{ "%.1f"|format(p*100) }}%){% if not loop.last %}, {% endif %}{% endfor %}</td></tr>
    {% if d.rec_components %}<tr><th>Why this tip</th><td>tendency {{ "%.2f"|format(d.rec_components.tendency) }} + home {{ "%.2f"|format(d.rec_components.home_goals) }} + away {{ "%.2f"|format(d.rec_components.away_goals) }} + diff {{ "%.2f"|format(d.rec_components.goal_diff) }} = <b>{{ "%.2f"|format(d.rec_components.total) }}</b> <span class="sub">· P(exact tip) {{ "%.1f"|format(d.rec_cell_prob*100) }}%</span></td></tr>{% endif %}
    {% if d.market_sources and d.market_sources.espn %}<tr><th>Market — ESPN</th><td>{{ "%.1f"|format(d.market_sources.espn.home*100) }}% / {{ "%.1f"|format(d.market_sources.espn.draw*100) }}% / {{ "%.1f"|format(d.market_sources.espn.away*100) }}%</td></tr>{% endif %}
    {% if d.market_sources and d.market_sources.poly %}<tr><th>Market — Polymarket</th><td>{{ "%.1f"|format(d.market_sources.poly.home*100) }}% / {{ "%.1f"|format(d.market_sources.poly.draw*100) }}% / {{ "%.1f"|format(d.market_sources.poly.away*100) }}%</td></tr>{% endif %}
    {% if d.market_probs %}<tr><th>Market — blended (de-vigged)</th><td>{{ "%.1f"|format(d.market_probs.home*100) }}% / {{ "%.1f"|format(d.market_probs.draw*100) }}% / {{ "%.1f"|format(d.market_probs.away*100) }}%</td></tr>{% endif %}
  </table>
</div>
{% endmacro %}
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Tippspiel Predictor — WC 2026</title>
<style>
  :root { --fg:#222; --muted:#666; --line:#e2e2e2; --accent:#2c7fb8; --tip:#e6550d; }
  * { box-sizing: border-box; }
  body { font-family: -apple-system, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
         color: var(--fg); line-height: 1.5; margin: 0; background:#fafafa; }
  .wrap { max-width: 980px; margin: 0 auto; padding: 24px 20px 80px; }
  h1 { font-size: 1.7rem; margin: 0 0 4px; }
  h2 { font-size: 1.3rem; border-bottom: 2px solid var(--line); padding-bottom: 6px;
       margin-top: 40px; }
  h3 { font-size: 1.05rem; margin: 24px 0 8px; }
  details.section { margin-top: 40px; }
  details.section > summary { cursor:pointer; list-style:none; display:flex;
       align-items:center; gap:10px; border-bottom:2px solid var(--line);
       padding-bottom:6px; }
  details.section > summary::-webkit-details-marker { display:none; }
  details.section > summary::before { content:"\25B8"; color:var(--muted);
       font-size:1rem; flex:0 0 auto; }
  details.section[open] > summary::before { content:"\25BE"; }
  details.section > summary h2 { border:none; margin:0; padding:0; flex:1 1 auto; }
  details.section > summary:hover h2 { color:var(--accent); }
  .section-body { margin-top: 8px; }
  .meta { color: var(--muted); font-size: .9rem; }
  .toc { background:#fff; border:1px solid var(--line); border-radius:8px; padding:14px 18px; }
  .toc ul { margin: 6px 0; padding-left: 20px; }
  .toc a { color: var(--accent); text-decoration: none; }
  .toc a:hover { text-decoration: underline; }
  .card { background:#fff; border:1px solid var(--line); border-radius:8px; padding:0;
          margin: 12px 0; overflow:hidden; }
  details > summary { cursor:pointer; padding:12px 16px; font-weight:600;
                      list-style:none; display:flex; justify-content:space-between;
                      align-items:center; gap:12px; }
  details > summary::-webkit-details-marker { display:none; }
  details[open] > summary { border-bottom:1px solid var(--line); }
  .summary-right { font-weight:400; color:var(--muted); font-size:.9rem; }
  .fixture-body { padding: 8px 16px 16px; }
  .tip-score { color:var(--tip); font-weight:700; font-size:1.15rem; }
  .badge { display:inline-block; background:#eef4f9; color:var(--accent);
           border-radius:10px; padding:1px 8px; font-size:.78rem; }
  .played { color: var(--muted); }
  .tag { display:inline-block; border-radius:10px; padding:1px 8px; font-size:.78rem;
         font-weight:600; }
  .tag-exact, .tag-expected { background:#e6f4ea; color:#1a7f37; }
  .tag-tendency, .tag-plausible { background:#fdf3dc; color:#9a6700; }
  .tag-miss, .tag-surprising { background:#fbe9e7; color:#c0392b; }
  table.kv { border-collapse:collapse; font-size:.9rem; }
  table.kv td { padding:2px 10px 2px 0; }
  table.kv th { padding:2px 10px 2px 0; text-align:left; color:var(--muted); font-weight:600; }
  table.standings { border-collapse:collapse; font-size:.9rem; width:100%; }
  table.standings th { text-align:right; color:var(--muted); font-weight:600; padding:4px 8px;
                       border-bottom:1px solid var(--line); }
  table.standings td { text-align:right; padding:4px 8px; border-bottom:1px solid var(--line); }
  table.standings th.team, table.standings td.team { text-align:left; }
  table.standings td.pts { font-weight:700; }
  table.standings tr.q td { background:#f3f9f4; }
  .through { color:#1a7f37; font-weight:700; margin-left:6px; }
  .fixture-data { margin:10px 0 4px; font-size:.85rem; }
  .fixture-data table.kv th { white-space:nowrap; vertical-align:top; }
  .fixture-data .sub { color:var(--muted); }
  .grid2 { display:grid; grid-template-columns: 1fr 1fr; gap:16px; }
  @media (max-width:760px){ .grid2 { grid-template-columns: 1fr; } }
  footer { margin-top:48px; padding-top:16px; border-top:1px solid var(--line);
           color:var(--muted); font-size:.85rem; }
  .pre { background:#f4f4f4; border-radius:6px; padding:8px 10px; font-size:.82rem;
         overflow-x:auto; }
</style>
<script type="text/javascript">{{ plotlyjs }}</script>
</head>
<body>
<div class="wrap">

  <h1>Tippspiel Predictor — FIFA World Cup 2026</h1>
  <p class="meta">
    Generated {{ header.generated_at }} ·
    Predictor <b>{{ header.predictor_name }}</b>
    {% if header.mc_iterations %} · MC {{ "{:,}".format(header.mc_iterations) }} iters (seed {{ header.mc_seed }}){% endif %}
    · {{ header.results_count }} result(s) incorporated
  </p>
  <table class="kv meta"><tr><td>Predictor params</td>
    <td><span class="pre">{{ header.predictor_params }}</span></td></tr></table>
  {% if header.uses_offdef %}<p class="meta">This run uses the <b>offensive/defensive Elo</b> goal-volume layer (<code>alpha &gt; 0</code>): each team's fitted <b>att</b> (higher = scores more) and <b>def</b> (higher = concedes fewer), centred over all international teams, nudge a match's predicted total goals up or down. Each fixture below shows the two teams' att/def and the net goal-volume effect on that matchup.</p>{% endif %}

  <div class="toc">
    <b>Contents</b>
    <ul>
      <li><a href="#groups">Group-stage fixtures</a></li>
      {% if group_standings %}<li><a href="#standings">Group standings</a></li>{% endif %}
      {% if advancement %}<li><a href="#advancement">Group advancement</a></li>{% endif %}
      {% if knockout_fixtures %}<li><a href="#knockout">Knockout fixtures</a></li>{% endif %}
      {% if title_odds_chart %}<li><a href="#title">Title odds</a></li>{% endif %}
      {% if bracket_html %}<li><a href="#bracket">Knockout bracket</a></li>{% endif %}
      {% if bonus %}<li><a href="#bonus">Bonus recommendations</a></li>{% endif %}
      {% if elo_history %}<li><a href="#elo-history">Elo ratings over time</a></li>{% endif %}
      <li><a href="#caveats">Caveats</a></li>
    </ul>
  </div>

  <details class="section" id="groups">
  <summary><h2>Group-stage fixtures</h2></summary>
  <div class="section-body">
  <p class="meta">All group matches in kickoff order; each is tagged with its group.</p>
  {% for fx in group_fixtures %}
    <div class="card"><details>
      <summary>
        <span><span class="badge">Group {{ fx.group }}</span> {{ fx.home }} vs {{ fx.away }}
          {% if fx.played %}<span class="played">· FT {{ fx.result.home_goals }}–{{ fx.result.away_goals }}</span>{% if fx.tip_outcome %} <span class="tag tag-{{ fx.tip_outcome.cls }}">{{ fx.tip_outcome.label }} · {{ fx.tip_outcome.points }}/{{ fx.tip_outcome.max }} pts</span>{% endif %}{% endif %}
        </span>
        <span class="summary-right">{{ fx.kickoff | localtime }}{% if fx.tip %} · Recommended tip <b class="tip-score">{{ fx.tip.home }}–{{ fx.tip.away }}</b> <span class="badge">EV {{ "%.2f"|format(fx.tip.ev) }} pts</span>{% if fx.naive %} <span class="meta">vs naive {{ fx.naive.home }}–{{ fx.naive.away }} (EV {{ "%.2f"|format(fx.naive.ev) }})</span>{% endif %}{% if fx.market_tip %} <span class="meta">· Market-odds tip: {{ fx.market_tip.home }}–{{ fx.market_tip.away }} (EV {{ "%.2f"|format(fx.market_tip.ev) }}{% if fx.market_tip.points is not none %}, scored {{ fx.market_tip.points }} pts{% endif %})</span>{% endif %}{% endif %}</span>
      </summary>
      <div class="fixture-body">
        {% if fx.played %}
          <p class="played">Played — actual result {{ fx.result.home_goals }}–{{ fx.result.away_goals }}.
            {%- if fx.actual %} The model gave this exact score {{ "%.1f"|format(fx.actual.p_exact*100) }}% and the tendency {{ "%.1f"|format(fx.actual.p_tendency*100) }}% — <span class="tag tag-{{ fx.actual.label }}">{{ fx.actual.label }}</span>.{% endif %}
            {%- if fx.tip_outcome %} Recommended tip scored <b>{{ fx.tip_outcome.points }}/{{ fx.tip_outcome.max }} pts</b>.{% endif %}
            (Tip and forecast below are the pre-match prediction.)</p>
        {% endif %}
        {% if fx.data %}{{ fixture_data(fx.data) }}{% endif %}
        {% if fx.ldw_chart %}
        <div class="grid2">
          <div>{{ fx.ldw_chart | safe }}</div>
          <div>{{ fx.heatmap | safe }}</div>
        </div>
        {% endif %}
      </div>
    </details></div>
  {% endfor %}
  </div>
  </details>

  {% if group_standings %}
  <details class="section" id="standings">
  <summary><h2>Group standings</h2></summary>
  <div class="section-body">
  <p class="meta">Current tables from the results played so far, ordered by points → goal difference
    → goals scored → head-to-head. A finished group's certain top two are marked
    <span class="through">✓ through</span> — these are the teams that fill the knockout bracket.</p>
  {% for s in group_standings %}
    <div class="card"><div class="fixture-body">
      <h3 style="margin-top:4px">Group {{ s.letter }}
        <span class="summary-right">· {{ "complete" if s.complete else "in progress" }}</span></h3>
      <table class="standings">
        <tr><th class="team">#</th><th class="team">Team</th><th>P</th><th>W</th><th>D</th>
            <th>L</th><th>GF</th><th>GA</th><th>GD</th><th>Pts</th></tr>
        {% for r in s.rows %}
        <tr{% if r.qualified %} class="q"{% endif %}>
          <td>{{ r.rank }}</td>
          <td class="team">{{ r.team }}{% if r.qualified %}<span class="through">✓ through</span>{% endif %}</td>
          <td>{{ r.played }}</td><td>{{ r.wins }}</td><td>{{ r.draws }}</td><td>{{ r.losses }}</td>
          <td>{{ r.gf }}</td><td>{{ r.ga }}</td><td>{{ "%+d"|format(r.gd) }}</td>
          <td class="pts">{{ r.points }}</td>
        </tr>
        {% endfor %}
      </table>
    </div></div>
  {% endfor %}
  </div>
  </details>
  {% endif %}

  {% if advancement %}
  <details class="section" id="advancement">
  <summary><h2>Group advancement</h2></summary>
  <div class="section-body">
  {% for a in advancement %}{{ a.advancement_chart | safe }}{% endfor %}
  </div>
  </details>
  {% endif %}

  {% if knockout_fixtures %}
  <details class="section" id="knockout">
  <summary><h2>Knockout fixtures</h2></summary>
  <div class="section-body">
  {% for fx in knockout_fixtures %}
    <div class="card"><details>
      <summary>
        <span><span class="badge">{{ fx.stage }}</span> {{ fx.home }} vs {{ fx.away }}
          {% if fx.played %}<span class="played">· {{ fx.result.home_goals }}–{{ fx.result.away_goals }}</span>{% if fx.tip_outcome %} <span class="tag tag-{{ fx.tip_outcome.cls }}">{{ fx.tip_outcome.label }} · {{ fx.tip_outcome.points }}/{{ fx.tip_outcome.max }} pts</span>{% endif %}{% endif %}
        </span>
        <span class="summary-right">{{ fx.kickoff | localtime }}{% if fx.tip %} · Recommended tip <b class="tip-score">{{ fx.tip.home }}–{{ fx.tip.away }}</b> <span class="badge">EV {{ "%.2f"|format(fx.tip.ev) }} pts (doubled)</span>{% if fx.market_tip %} <span class="meta">· Market-odds tip: {{ fx.market_tip.home }}–{{ fx.market_tip.away }} (EV {{ "%.2f"|format(fx.market_tip.ev) }}{% if fx.market_tip.points is not none %}, scored {{ fx.market_tip.points }} pts{% endif %})</span>{% endif %}{% else %} · participants TBD{% endif %}</span>
      </summary>
      <div class="fixture-body">
        {% if fx.played %}
          <p class="played">Played — actual result {{ fx.result.home_goals }}–{{ fx.result.away_goals }}.
            {%- if fx.actual %} The model gave this exact score {{ "%.1f"|format(fx.actual.p_exact*100) }}% and the tendency {{ "%.1f"|format(fx.actual.p_tendency*100) }}% — <span class="tag tag-{{ fx.actual.label }}">{{ fx.actual.label }}</span>.{% endif %}
            {%- if fx.tip_outcome %} Recommended tip scored <b>{{ fx.tip_outcome.points }}/{{ fx.tip_outcome.max }} pts</b>.{% endif %}
            (Tip and forecast below are the pre-match prediction.)</p>
        {% endif %}
        {% if fx.tip %}
          {% if fx.data %}{{ fixture_data(fx.data) }}{% endif %}
          <div class="grid2"><div>{{ fx.ldw_chart | safe }}</div><div>{{ fx.heatmap | safe }}</div></div>
        {% elif not fx.played %}
          <p class="meta">{{ fx.slot_note }}</p>
          {% if fx.occupants_chart %}{{ fx.occupants_chart | safe }}{% endif %}
        {% endif %}
      </div>
    </details></div>
  {% endfor %}
  </div>
  </details>
  {% endif %}

  {% if title_odds_chart %}
  <details class="section" id="title">
  <summary><h2>Title odds</h2></summary>
  <div class="section-body">
  {{ title_odds_chart | safe }}
  </div>
  </details>
  {% endif %}

  {% if bracket_html %}
  <details class="section" id="bracket">
  <summary><h2>Knockout bracket</h2></summary>
  <div class="section-body">
  {{ bracket_html | safe }}
  </div>
  </details>
  {% endif %}

  {% if bonus %}
  <details class="section" id="bonus">
  <summary><h2>Bonus recommendations</h2></summary>
  <div class="section-body">
  {% for b in bonus %}
    <div class="card"><div class="fixture-body">
      <h3 style="margin-top:4px">{{ b.question }} <span class="badge">{{ b.points }} pts</span></h3>
      <p>Recommended: <b>{{ b.answer }}</b> ({{ "%.1f"|format(b.prob*100) }}%)
        {% if b.runner_up %}· runner-up {{ b.runner_up }} ({{ "%.1f"|format(b.runner_up_prob*100) }}%){% endif %}</p>
      {% if b.chart %}{{ b.chart | safe }}{% endif %}
    </div></div>
  {% endfor %}
  </div>
  </details>
  {% endif %}

  {% if elo_history %}
  <details class="section" id="elo-history">
  <summary><h2>Elo ratings over time</h2></summary>
  <div class="section-body">
  <p class="meta">The model's corpus-fitted ratings replayed from {{ elo_history.window_start }}
    to {{ elo_history.snapshot }} (the fit's snapshot cutoff):
    the scalar <b>Elo</b> (who wins) and the offensive/defensive <b>att/def</b> ratings
    (goal volume). Each line ends at the rating the predictor uses today. The strongest
    8 sides by current Elo are shown; click a gray legend entry to add any other team.
    att/def are log goal-rates relative to the international field (0 = average), shown on
    the final fit pass and centred at the end-of-window field means.</p>
  {{ elo_history.elo_chart | safe }}
  {{ elo_history.att_chart | safe }}
  {{ elo_history.def_chart | safe }}
  </div>
  </details>
  {% endif %}

  <footer>
    <details class="section" id="caveats">
    <summary><h2 style="border:none">Caveats</h2></summary>
    <div class="section-body"><p>{{ caveats }}</p></div>
    </details>
  </footer>

</div>
<script type="text/javascript">
(function () {
  function openTarget() {
    var id = decodeURIComponent((location.hash || "").slice(1));
    if (!id) return;
    var el = document.getElementById(id);
    if (!el) return;
    var section = el.closest ? el.closest("details.section") : null;
    if (el.tagName === "DETAILS") el.open = true;
    if (section) section.open = true;
    if (el.scrollIntoView) el.scrollIntoView();
  }
  window.addEventListener("hashchange", openTarget);
  if (document.readyState !== "loading") openTarget();
  else document.addEventListener("DOMContentLoaded", openTarget);

  // Lazy chart rendering: figures are embedded as inert JSON (.lazy-plot) and drawn the
  // first time they become visible — the report carries ~200 figures, all inside closed
  // <details>, and rendering them eagerly blocks page load for many seconds. Rendering on
  // reveal also gives Plotly the real container width to size against.
  var PLOT_CONFIG = { responsive: true, displaylogo: false };
  function renderPlots(scope) {
    var nodes = (scope || document).querySelectorAll(".lazy-plot:not([data-rendered])");
    for (var i = 0; i < nodes.length; i++) {
      var el = nodes[i];
      // Skip while any ancestor <details> is closed (offsetParent can't detect this:
      // Chromium hides closed-details content via content-visibility, not display:none).
      if (el.closest("details:not([open])")) continue;
      var spec = JSON.parse(el.firstElementChild.textContent);
      el.setAttribute("data-rendered", "1");
      el.removeChild(el.firstElementChild);
      Plotly.newPlot(el, spec.data, spec.layout, PLOT_CONFIG);
    }
  }
  // toggle doesn't bubble, so listen in the capture phase; covers sections and fixture cards.
  document.addEventListener("toggle", function (e) {
    if (e.target.open) renderPlots(e.target);
  }, true);
  renderPlots(document);
})();
</script>
</body>
</html>
